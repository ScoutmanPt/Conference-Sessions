{
  "type": "AdaptiveCard",
  "version": "1.6",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "${iconUrl}",
              "horizontalAlignment": "center",
              "size": "small",
              "altText": "Clinical protocol"
            }
          ],
          "horizontalAlignment": "center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "[${title}](${titleUrl})",
              "weight": "bolder",
              "size": "medium",
              "maxLines": 2,
              "color": "accent"
            },
            {
              "type": "TextBlock",
              "text": "${protocolCode} | ${department} | ${fileType}",
              "spacing": "small",
              "maxLines": 1,
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "Owner: ${author}",
              "spacing": "small",
              "maxLines": 1
            },
            {
              "type": "TextBlock",
              "text": "Modified by ${modifiedBy}",
              "spacing": "small",
              "maxLines": 1
            }
          ],
          "spacing": "medium"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json"
}
