 {
        "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
        "type": "AdaptiveCard",
        "version": "1.5",
        "body": [
          {
            "type": "ColumnSet",
            "columns": [
              {
                "items": [
                  {
                    "text": "' + $CardCaption + '",
                    "size": "Large",
                    "weight": "Bolder",
                    "color": "Attention",
                    "wrap": true,
                    "type": "TextBlock"
                  },
                  {
                    "text": "' + $CardTitle + '",
                    "size": "extraLarge",
                    "weight": "bolder",
                    "spacing": "none",
                    "wrap": true,
                    "type": "TextBlock"
                  },
                  {
                    "type": "TextBlock",
                    "size": "small",
                    "maxLines": 1,
                    "text": "' + $CardSubTitle + '",
                    "wrap": true
                  },
                  {
                    "type": "TextBlock",
                    "size": "small",
                    "text": "' + $CardText + ' [' + $CardText1Link + '](' + $CardText1LinkUrl + ')",
                    "wrap": true
                  }
                ],
                "type": "Column",
                "width": 2
              },
              {
                "items": [
                  {
                    "type": "Image",
                    "url": "' + $image + '",
                    "altText": "1",
                    "width": "' + $imageSize + '"
                  }
                ],
                "type": "Column",
                "width": 1
              }
            ]
          }
        ],
        "actions": [
          {
            "type": "Action.OpenUrl",
            "url": "' + $CardButtonRedirect + '",
            "title": "' + $CardButtonText + '"
          }
        ]
      }